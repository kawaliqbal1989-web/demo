NODE_ENV=development
PORT=4000

# Prisma / MySQL
# Note: this repo's Jest setup commonly uses MySQL on localhost:3307.
DATABASE_URL="mysql://root:password@localhost:3307/abacusweb"
SHADOW_DATABASE_URL="mysql://root:password@localhost:3307/abacusweb_shadow"
DATABASE_URL_TEST="mysql://root:password@localhost:3307/abacusweb_test"

# JWT config (development defaults are fine locally; change for production)
JWT_ACCESS_SECRET="dev"
JWT_REFRESH_SECRET="dev"
JWT_ISSUER="dev"
JWT_AUDIENCE="dev"
JWT_ACCESS_EXPIRES_IN="20m"
JWT_REFRESH_EXPIRES_IN="7d"

REQUEST_BODY_LIMIT="1mb"
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Comma-separated allowlist for production frontend origins
# Example: CORS_ALLOWED_ORIGINS="https://app.example.com,https://www.app.example.com"
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# Optional: Settlement cron default tenant
# TENANT_ID=tenant_default

# Rate limiting for KPI/analytics endpoints
# KPI_RATE_LIMIT_WINDOW_MS=60000
# KPI_RATE_LIMIT_MAX=120

# Gemini AI Playground
# GEMINI_API_KEY=""
# GEMINI_MODEL="gemini-2.0-flash"
# AI_DAILY_LIMIT=30
