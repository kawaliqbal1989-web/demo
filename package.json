{
  "name": "abacusweb-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "smoke:mock-fixture": "node scripts/smoke-create-online-mock-fixture.mjs",
    "e2e": "node scripts/e2e-run.mjs test",
    "e2e:ui": "node scripts/e2e-run.mjs test --ui",
    "e2e:report": "playwright show-report",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "test:security": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand tests/security/superadmin.security.test.js",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch --runInBand",
    "prisma:generate": "node scripts/run-prisma.mjs generate",
    "prisma:migrate": "node scripts/run-prisma.mjs migrate dev",
    "prisma:deploy": "node scripts/run-prisma.mjs migrate deploy",
    "prisma:seed": "node scripts/run-prisma.mjs db seed",
    "prisma:pilot-seed": "node prisma/pilot-seed.js",
    "migrate:plan": "node scripts/run-migrations.mjs --dry-run",
    "migrate:run": "node scripts/run-migrations.mjs",
    "verify:deploy": "node scripts/verify-deployment.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.9",
    "prisma": "^6.3.1",
    "supertest": "^7.2.2"
  }
}
