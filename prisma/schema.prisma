  signatoryName        String?
  signatoryDesignation String?
  signatureImagePath   String?
  signatureImageUrl    String?         @db.Text
  affiliationLogoPath  String?
  affiliationLogoUrl   String?         @db.Text
  stampImagePath       String?
  stampImageUrl        String?         @db.Text
  backgroundImagePath  String?
  backgroundImageUrl   String?         @db.Text
  layout               Json?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  businessPartner      BusinessPartner @relation(fields: [businessPartnerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ─── Phase 4: Intelligence Platform ───────────────────────────

enum InsightCategory {
  RISK
  PERFORMANCE
  ATTENDANCE
  FINANCIAL
  PROMOTION
  ENGAGEMENT
  OPERATIONAL
  COMPLIANCE
}

enum InsightSeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

model Insight {
  id           String          @id @default(cuid())
  tenantId     String
  targetRole   Role
  targetUserId String
  category     InsightCategory
  severity     InsightSeverity
  title        String
  message      String          @db.Text
  actionLabel  String?
  actionUrl    String?
  entityType   String?
  entityId     String?
  metadata     Json?
  isDismissed  Boolean         @default(false)
  isActioned   Boolean         @default(false)
  expiresAt    DateTime?
  createdAt    DateTime        @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  targetUser AuthUser @relation("InsightTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([tenantId, targetUserId, isDismissed, createdAt])
  @@index([tenantId, targetRole, category, createdAt])
  @@index([tenantId, severity, createdAt])
  @@index([expiresAt])
}

// ─── Phase 5: Student Premium Experience ──────────────────────────

model StudentMilestone {
  id          String   @id @default(cuid())
  tenantId    String
  studentId   String
  key         String
  title       String
  description String?
  icon        String?
  earnedAt    DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([tenantId, studentId, key])
  @@index([tenantId, studentId, earnedAt])
}
