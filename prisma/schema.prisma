// Layer 1: Superadmin → BP entitlement for practice features
model BusinessPartnerPracticeEntitlement {
  id                String             @id @default(cuid())
  tenantId          String
  businessPartnerId String
  featureKey        PracticeFeatureKey
  isEnabled         Boolean            @default(false)
  totalSeats        Int                @default(0)
  createdByUserId   String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant            Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  businessPartner   BusinessPartner            @relation(fields: [businessPartnerId], references: [id], onDelete: Cascade)
  createdBy         AuthUser                   @relation("PracticeEntitlementCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  centerAllocations CenterPracticeAllocation[]

  @@unique([tenantId, businessPartnerId, featureKey])
  @@index([tenantId, businessPartnerId])
}

// Layer 2: BP/Franchise → Center seat allocation
model CenterPracticeAllocation {
  id                String   @id @default(cuid())
  tenantId          String
  entitlementId     String
  centerNodeId      String // hierarchyNodeId of the center
  allocatedSeats    Int      @default(0)
  allocatedByUserId String
  allocatedByRole   String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant             Tenant                             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  entitlement        BusinessPartnerPracticeEntitlement @relation(fields: [entitlementId], references: [id], onDelete: Cascade)
  centerNode         HierarchyNode                      @relation("CenterPracticeAllocationNode", fields: [centerNodeId], references: [id], onDelete: Cascade)
  allocatedBy        AuthUser                           @relation("PracticeAllocationAllocatedBy", fields: [allocatedByUserId], references: [id], onDelete: Restrict)
  studentAssignments StudentPracticeAssignment[]

  @@unique([tenantId, entitlementId, centerNodeId])
  @@index([tenantId, centerNodeId])
  @@index([entitlementId])
}

// Layer 3: Center → Student feature assignment
model StudentPracticeAssignment {
  id                 String             @id @default(cuid())
  tenantId           String
  allocationId       String
  studentId          String
  featureKey         PracticeFeatureKey // denormalized for fast lookup
  isActive           Boolean            @default(true)
  assignedByUserId   String
  assignedAt         DateTime           @default(now())
  unassignedAt       DateTime?
  unassignedByUserId String?

  tenant       Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  allocation   CenterPracticeAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  student      Student                  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignedBy   AuthUser                 @relation("PracticeAssignmentAssignedBy", fields: [assignedByUserId], references: [id], onDelete: Restrict)
  unassignedBy AuthUser?                @relation("PracticeAssignmentUnassignedBy", fields: [unassignedByUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, studentId, featureKey])
  @@index([tenantId, allocationId, isActive])
  @@index([tenantId, studentId, featureKey, isActive])
  @@index([assignedByUserId])
}

model WorksheetReassignmentRequest {
