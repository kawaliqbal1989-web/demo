generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum Role {
  SUPERADMIN
  BP
  FRANCHISE
  CENTER
  TEACHER
  STUDENT
}

enum HierarchyType {
  COUNTRY
  REGION
  DISTRICT
  SCHOOL
  BRANCH
}

enum WorksheetDifficulty {
  EASY
  MEDIUM
  HARD
}

enum WorksheetGenerationMode {
  PRACTICE
  EXAM
}

enum MaterialType {
  LINK
  FILE
}

enum AbuseFlagType {
  RAPID_SUBMISSION
  PERFECT_STREAK
  TIME_ANOMALY
  COMPETITION_SPIKE
}

enum NotificationType {
  PROMOTION_READY
  PROMOTION_CONFIRMED
  COMPETITION_STAGE_UPDATE
  ABUSE_FLAG_CREATED
  SYSTEM_BROADCAST

  EXAM_CYCLE_CREATED
  EXAM_ENROLLMENT_OPEN
  EXAM_ENROLLMENT_CLOSING_SOON
  EXAM_LIST_SUBMITTED
  EXAM_LIST_APPROVED
  EXAM_PRACTICE_STARTED
  EXAM_STARTING_TOMORROW
  EXAM_LIVE
  EXAM_LAST_DAY_REMINDER
  EXAM_RESULT_PUBLISHED
  EXAM_RESULT_UNPUBLISHED

  RISK_ALERT
  FEE_OVERDUE
  FEE_UPCOMING
  ATTENDANCE_DROP
  STALE_BATCH
  WORKFLOW_REMINDER
  HEALTH_SCORE_DROP
  TEACHER_OVERLOAD
  ADMISSION_MILESTONE
  DIGEST_DAILY
  DIGEST_WEEKLY
}

enum NotificationPriority {
  CRITICAL
  HIGH
  NORMAL
  LOW
}

enum NotificationCategory {
  WORKFLOW
  RISK
  FINANCE
  ACADEMIC
  OPERATIONS
  SYSTEM
}

enum ExamEnrollmentStatus {
  DRAFT
  SUBMITTED_TO_CENTER
  SUBMITTED_TO_FRANCHISE
  SUBMITTED_TO_BUSINESS_PARTNER
  SUBMITTED_TO_SUPERADMIN
  APPROVED
  REJECTED
}

enum ExamEnrollmentListType {
  TEACHER
  CENTER_COMBINED
}

enum ExamResultStatus {
  DRAFT
  LOCKED
  PUBLISHED
}

enum SubmissionStatus {
  PENDING
  REVIEWED
  REJECTED
}

enum CompetitionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum CompetitionResultStatus {
  DRAFT
  LOCKED
  PUBLISHED
}

enum CompetitionPartnerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CompetitionWorkflowStage {
  CENTER_REVIEW
  FRANCHISE_REVIEW
  BP_REVIEW
  SUPERADMIN_APPROVAL
  APPROVED
  REJECTED
}

enum CompetitionTransitionAction {
  FORWARD
  REJECT
}

enum FinancialTransactionType {
  ENROLLMENT
  RENEWAL
  COMPETITION
  ADJUSTMENT
}

enum PaymentMode {
  CASH
  ONLINE
  GPAY
  PAYTM
}

enum FeeScheduleType {
  ADVANCE
  MONTHLY
  LEVEL_WISE
}

enum SubscriptionStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum BusinessPartnerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BusinessType {
  INDIVIDUAL
  COMPANY
}

enum PartnerAccessMode {
  ALL
  SELECTIVE
}

enum PracticeFeatureKey {
  PRACTICE
  ABACUS_PRACTICE
}

enum CertificateStatus {
  ISSUED
  REVOKED
}

enum FranchiseStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum CenterStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ARCHIVED
}

enum SettlementStatus {
  PENDING
  PAID
}

enum BatchStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  INACTIVE
  TRANSFERRED
  ARCHIVED
}

enum AttendanceSessionStatus {
  DRAFT
  PUBLISHED
  LOCKED
  CANCELLED
}

enum AttendanceEntryStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AttendanceCorrectionStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
}

enum MockTestStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MockTestAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  TIMED_OUT
}

enum WorksheetReassignmentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum WorksheetReassignmentType {
  RETRY
  SWAP
}

enum TeacherStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Tenant {
  id                               String                           @id @default(cuid())
  name                             String
  code                             String                           @unique
  createdAt                        DateTime                         @default(now())
  updatedAt                        DateTime                         @updatedAt
  authUsers                        AuthUser[]
  superadmins                      Superadmin[]
  hierarchyNodes                   HierarchyNode[]
  levels                           Level[]
  courses                          Course[]
  studentAssignedCourses           StudentAssignedCourse[]
  courseLevels                     CourseLevel[]
  students                         Student[]
  teacherNotes                     TeacherNote[]
  worksheets                       Worksheet[]
  materials                        Material[]
  submissions                      WorksheetSubmission[]
  worksheetAssignments             WorksheetAssignment[]
  competitions                     Competition[]
  competitionBusinessPartners      CompetitionBusinessPartner[]
  competitionStageTransitions      CompetitionStageTransition[]
  competitionLinks                 CompetitionWorksheet[]
  enrollments                      CompetitionEnrollment[]
  refreshTokens                    RefreshToken[]
  auditLogs                        AuditLog[]
  businessPartners                 BusinessPartner[]
  margins                          Margin[]
  settlements                      Settlement[]
  levelRules                       LevelRule[]
  studentLevelCompletions          StudentLevelCompletion[]
  studentLevelProgressionHistories StudentLevelProgressionHistory[]
  worksheetQuestions               WorksheetQuestion[]
  worksheetTemplates               WorksheetTemplate[]
  questionBankEntries              QuestionBank[]
  userSequences                    UserSequence[]
  abuseFlags                       AbuseFlag[]
  notifications                    Notification[]
  notificationPreferences          NotificationPreference[]
  financialTransactions            FinancialTransaction[]
  feeInstallments                  StudentFeeInstallment[]
  certificates                     Certificate[]
  franchiseProfiles                FranchiseProfile[]
  franchiseAddresses               FranchiseAddress[]
  centerProfiles                   CenterProfile[]
  centerAddresses                  CenterAddress[]
  teacherProfiles                  TeacherProfile[]
  batches                          Batch[]
  batchTeacherAssignments          BatchTeacherAssignment[]
  batchEnrollments                 Enrollment[]
  attendanceSessions               AttendanceSession[]
  attendanceEntries                AttendanceEntry[]
  attendanceCorrectionRequests     AttendanceCorrectionRequest[]
  mockTests                        MockTest[]
  mockTestResults                  MockTestResult[]

  examCycles                             ExamCycle[]
  examPracticePlans                      ExamPracticePlan[]
  examTextbookData                       ExamTextbookData[]
  examEnrollmentLists                    ExamEnrollmentList[]
  examEnrollmentEntries                  ExamEnrollmentEntry[]
  examEnrollmentListItems                ExamEnrollmentListItem[]
  examEnrollmentLevelWorksheetSelections ExamEnrollmentLevelWorksheetSelection[]
  aiPlaygroundLogs                       AiPlaygroundLog[]
  aiCustomTools                          AiCustomTool[]
  worksheetReassignmentRequests          WorksheetReassignmentRequest[]
  businessPartnerPracticeEntitlements    BusinessPartnerPracticeEntitlement[]
  centerPracticeAllocations              CenterPracticeAllocation[]
  studentPracticeAssignments             StudentPracticeAssignment[]
  certificateTemplates                   CertificateTemplate[]
  insights                               Insight[]
  studentMilestones                      StudentMilestone[]

  @@map("tenant")
}

model IdempotencyKey {
  id               String   @id @default(cuid())
  tenantId         String
  key              String
  method           String
  path             String
  requestHash      String?
  responseEntityId String?
  responseStatus   Int?
  responseBody     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([tenantId, key, method, path])
  @@index([tenantId, key])
    @@map("tdempotencykey")
}

model AuthUser {
  id                             String                           @id @default(cuid())
  username                       String?
  email                          String
  passwordHash                   String
  role                           Role
  isActive                       Boolean                          @default(true)
  failedAttempts                 Int                              @default(0)
  lockUntil                      DateTime?
  mustChangePassword             Boolean                          @default(false)
  tenantId                       String
  parentUserId                   String?
  hierarchyNodeId                String?
  studentId                      String?                          @unique
  createdAt                      DateTime                         @default(now())
  updatedAt                      DateTime                         @updatedAt
  tenant                         Tenant                           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  parentUser                     AuthUser?                        @relation("AuthUserHierarchy", fields: [parentUserId], references: [id], onDelete: SetNull)
  childUsers                     AuthUser[]                       @relation("AuthUserHierarchy")
  hierarchyNode                  HierarchyNode?                   @relation(fields: [hierarchyNodeId], references: [id], onDelete: SetNull)
  student                        Student?                         @relation(fields: [studentId], references: [id], onDelete: SetNull)
  refreshTokens                  RefreshToken[]
  auditLogs                      AuditLog[]
  worksheetsCreated              Worksheet[]
  competitionsCreated            Competition[]
  competitionsRejected           Competition[]                    @relation("CompetitionRejectedBy")
  competitionStageTransitions    CompetitionStageTransition[]
  createdPartners                BusinessPartner[]                @relation("PartnerCreatedBy")
  resolvedAbuseFlags             AbuseFlag[]                      @relation("AbuseResolvedBy")
  notificationsReceived          Notification[]                   @relation("NotificationRecipient")
  notificationPreferences        NotificationPreference[]         @relation("NotificationPreferences")
  superadminProfile              Superadmin?
  promotedProgressions           StudentLevelProgressionHistory[]
  financialTransactions          FinancialTransaction[]
  certificatesIssued             Certificate[]                    @relation("CertificateIssuedBy")
  certificatesRevoked            Certificate[]                    @relation("CertificateRevokedBy")
  franchiseProfile               FranchiseProfile?
  centerProfile                  CenterProfile?
  teacherProfile                 TeacherProfile?
  batchTeacherAssignments        BatchTeacherAssignment[]
  assignedEnrollments            Enrollment[]                     @relation("EnrollmentAssignedTeacher")
  attendanceSessionsCreated      AttendanceSession[]              @relation("AttendanceSessionCreatedBy")
  attendanceEntriesMarked        AttendanceEntry[]                @relation("AttendanceEntryMarkedBy")
  attendanceCorrectionsRequested AttendanceCorrectionRequest[]    @relation("AttendanceCorrectionRequestedBy")
  attendanceCorrectionsReviewed  AttendanceCorrectionRequest[]    @relation("AttendanceCorrectionReviewedBy")
  mockTestsCreated               MockTest[]                       @relation("MockTestCreatedBy")
  mockTestResultsRecorded        MockTestResult[]                 @relation("MockTestResultRecordedBy")
  teacherNotes                   TeacherNote[]

  studentsAsCurrentTeacher Student[] @relation("StudentCurrentTeacher")

  worksheetAssignmentsCreated WorksheetAssignment[] @relation("WorksheetAssignmentCreatedBy")

  examCyclesCreated            ExamCycle[]           @relation("ExamCycleCreatedBy")
  examEnrollmentListsCreated   ExamEnrollmentList[]  @relation("ExamEnrollmentListCreatedBy")
  examEnrollmentListsRejected  ExamEnrollmentList[]  @relation("ExamEnrollmentListRejectedBy")
  examEnrollmentEntriesCreated ExamEnrollmentEntry[] @relation("ExamEnrollmentEntryCreatedBy")

  examEnrollmentListsAsTeacher         ExamEnrollmentList[]  @relation("ExamEnrollmentListTeacherUser")
  examEnrollmentEntriesAsSourceTeacher ExamEnrollmentEntry[] @relation("ExamEnrollmentEntrySourceTeacher")

  createdExamPracticePlans ExamPracticePlan[] @relation("ExamPracticePlanCreatedBy")
  createdExamTextbookData  ExamTextbookData[] @relation("ExamTextbookDataCreatedBy")

  examEnrollmentLevelWorksheetSelectionsCreated ExamEnrollmentLevelWorksheetSelection[] @relation("ExamEnrollmentLevelWorksheetSelectionCreatedBy")

  worksheetReassignmentRequestsCreated  WorksheetReassignmentRequest[] @relation("WorksheetReassignRequestedBy")
  worksheetReassignmentRequestsReviewed WorksheetReassignmentRequest[] @relation("WorksheetReassignReviewedBy")

  practiceEntitlementsCreated   BusinessPartnerPracticeEntitlement[] @relation("PracticeEntitlementCreatedBy")
  practiceAllocationsAllocated  CenterPracticeAllocation[]           @relation("PracticeAllocationAllocatedBy")
  practiceAssignmentsAssigned   StudentPracticeAssignment[]          @relation("PracticeAssignmentAssignedBy")
  practiceAssignmentsUnassigned StudentPracticeAssignment[]          @relation("PracticeAssignmentUnassignedBy")

  insightsReceived Insight[] @relation("InsightTarget")

  @@unique([tenantId, email])
  @@unique([tenantId, username])
  @@index([tenantId])
  @@index([username])
  @@index([tenantId, role])
  @@index([parentUserId])
  @@index([role])
  @@index([hierarchyNodeId])
  @@index([tenantId, createdAt, id])
  @@index([tenantId, role, createdAt])
   @@map("authuser")
}

model UserSequence {
  id        String   @id @default(cuid())
  tenantId  String
  role      Role
  nextValue Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, role])
  @@index([tenantId])
   @@map("usersequence")
}

model Notification {
  id              String               @id @default(cuid())
  tenantId        String
  recipientUserId String
  type            NotificationType
  priority        NotificationPriority @default(NORMAL)
  category        NotificationCategory @default(SYSTEM)
  title           String
  message         String
  entityType      String?
  entityId        String?
  actionUrl       String?
  expiresAt       DateTime?
  isRead          Boolean              @default(false)
  createdAt       DateTime             @default(now())
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  recipientUser   AuthUser             @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([tenantId, recipientUserId, isRead])
  @@index([tenantId, recipientUserId, priority])
  @@index([tenantId, createdAt])
  @@index([expiresAt])
  @@map("notification")
}

model NotificationPreference {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  type      NotificationType
  enabled   Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user      AuthUser         @relation("NotificationPreferences", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, type])
  @@index([tenantId, userId])
  @@map("notificationpreference")
}

model Superadmin {
  id         String    @id @default(cuid())
  tenantId   String
  authUserId String?   @unique
  email      String
  fullName   String
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  authUser   AuthUser? @relation(fields: [authUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, email])
  @@index([tenantId])
   @@map("superadmin")
}

model HierarchyNode {
  id                    String                 @id @default(cuid())
  tenantId              String
  name                  String
  code                  String?
  type                  HierarchyType
  parentId              String?
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  parent                HierarchyNode?         @relation("HierarchyChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children              HierarchyNode[]        @relation("HierarchyChildren")
  students              Student[]
  competitions          Competition[]          @relation("CompetitionNode")
  users                 AuthUser[]
  partners              BusinessPartner[]
  centerTransactions    FinancialTransaction[] @relation("FinancialCenter")
  franchiseTransactions FinancialTransaction[] @relation("FinancialFranchise")
  batches               Batch[]
  enrollments           Enrollment[]
  attendanceSessions    AttendanceSession[]
  teacherProfiles       TeacherProfile[]
  teacherNotes          TeacherNote[]
  mockTests             MockTest[]

  examEnrollmentLists       ExamEnrollmentList[]       @relation("ExamEnrollmentListCenterNode")
  centerPracticeAllocations CenterPracticeAllocation[] @relation("CenterPracticeAllocationNode")

  @@unique([tenantId, code])
  @@index([tenantId, type])
  @@index([parentId])
  @@index([tenantId, createdAt, id])
  @@map("hierarchynode")
}

model TeacherProfile {
  id                       String        @id @default(cuid())
  tenantId                 String
  hierarchyNodeId          String
  authUserId               String        @unique
  fullName                 String
  phonePrimary             String?
  joiningDate              DateTime?
  qualification            String?
  experienceYears          Int?
  specialization           String?
  phoneAlternate           String?
  whatsappNumber           String?
  address                  String?
  city                     String?
  state                    String?
  pincode                  String?
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  photoUrl                 String?
  notes                    String?
  preferredLanguage        String?
  employmentType           String?
  salaryType               String?
  isProbation              Boolean?
  status                   TeacherStatus @default(ACTIVE)
  isActive                 Boolean       @default(true)
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  tenant                   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  centerNode               HierarchyNode @relation(fields: [hierarchyNodeId], references: [id], onDelete: Cascade)
  authUser                 AuthUser      @relation(fields: [authUserId], references: [id], onDelete: Cascade)

  @@index([tenantId, hierarchyNodeId, status, isActive])
  @@index([hierarchyNodeId, createdAt])
   @@map("teacherprofile")
}

model TeacherNote {
  id              String        @id @default(cuid())
  tenantId        String
  hierarchyNodeId String
  teacherUserId   String
  studentId       String
  note            String
  tags            Json?
  isDeleted       Boolean       @default(false)
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  centerNode      HierarchyNode @relation(fields: [hierarchyNodeId], references: [id], onDelete: Cascade)
  teacher         AuthUser      @relation(fields: [teacherUserId], references: [id], onDelete: Cascade)
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId, hierarchyNodeId, createdAt])
  @@index([tenantId, teacherUserId, createdAt])
  @@index([tenantId, studentId, createdAt])
    @@map("teachernote")
}

model Batch {
  id                 String                   @id @default(cuid())
  tenantId           String
  hierarchyNodeId    String
  name               String
  schedule           Json?
  status             BatchStatus              @default(ACTIVE)
  isActive           Boolean                  @default(true)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  tenant             Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  centerNode         HierarchyNode            @relation(fields: [hierarchyNodeId], references: [id], onDelete: Cascade)
  teacherAssignments BatchTeacherAssignment[]
  enrollments        Enrollment[]
  attendanceSessions AttendanceSession[]
  mockTests          MockTest[]

  @@unique([tenantId, hierarchyNodeId, name])
  @@index([tenantId, hierarchyNodeId, status, isActive])
  @@index([hierarchyNodeId, createdAt])
   @@map("batch")
}

model BatchTeacherAssignment {
  batchId       String
  teacherUserId String
  tenantId      String
  createdAt     DateTime @default(now())
  batch         Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  teacher       AuthUser @relation(fields: [teacherUserId], references: [id], onDelete: Cascade)
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@id([batchId, teacherUserId])
  @@index([tenantId, teacherUserId])
  @@index([tenantId, batchId])
   @@map("batchteacherassignment")
}

model Enrollment {
  id                    String           @id @default(cuid())
  tenantId              String
  hierarchyNodeId       String
  studentId             String
  batchId               String
  assignedTeacherUserId String?
  levelId               String?
  startDate             DateTime?
  status                EnrollmentStatus @default(ACTIVE)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  tenant                Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  centerNode            HierarchyNode    @relation(fields: [hierarchyNodeId], references: [id], onDelete: Cascade)
  student               Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batch                 Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  assignedTeacher       AuthUser?        @relation("EnrollmentAssignedTeacher", fields: [assignedTeacherUserId], references: [id], onDelete: SetNull)
  level                 Level?           @relation(fields: [levelId], references: [id], onDelete: SetNull)

  @@index([tenantId, hierarchyNodeId, status])
  @@index([tenantId, studentId, status])
  @@index([tenantId, batchId, status])
  @@index([assignedTeacherUserId])
  @@map("enrollment")
}

model AttendanceSession {
  id                 String                        @id @default(cuid())
  tenantId           String
  hierarchyNodeId    String
  batchId            String
  date               DateTime
  status             AttendanceSessionStatus       @default(DRAFT)
  version            Int                           @default(1)
  createdByUserId    String?
  publishedAt        DateTime?
  lockedAt           DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt
  tenant             Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  centerNode         HierarchyNode                 @relation(fields: [hierarchyNodeId], references: [id], onDelete: Cascade)
  batch              Batch                         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdBy          AuthUser?                     @relation("AttendanceSessionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  entries            AttendanceEntry[]
  correctionRequests AttendanceCorrectionRequest[]

  @@unique([tenantId, batchId, date])
  @@index([tenantId, hierarchyNodeId, date])
  @@index([tenantId, batchId, date, status])
   @@map("attendancesession")
}

model AttendanceEntry {
  sessionId      String
  studentId      String
  tenantId       String
  status         AttendanceEntryStatus
  note           String?
  markedAt       DateTime?
  markedByUserId String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  session        AttendanceSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student        Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  markedBy       AuthUser?             @relation("AttendanceEntryMarkedBy", fields: [markedByUserId], references: [id], onDelete: SetNull)

  @@id([sessionId, studentId])
  @@index([tenantId, sessionId])
  @@index([tenantId, studentId])
  @@map("attendanceentry")
}

model AttendanceCorrectionRequest {
  id                String                     @id @default(cuid())
  tenantId          String
  sessionId         String
  requestedByUserId String
  status            AttendanceCorrectionStatus @default(PENDING)
  reason            String
  requestedChanges  Json
  reviewedByUserId  String?
  reviewedAt        DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  tenant            Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  session           AttendanceSession          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  requestedBy       AuthUser                   @relation("AttendanceCorrectionRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  reviewedBy        AuthUser?                  @relation("AttendanceCorrectionReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, sessionId, status])
  @@index([tenantId, createdAt])
   @@map("attendancecorrectionrequest")
}

model Level {
  id                                     String                                  @id @default(cuid())
  tenantId                               String
  name                                   String
  rank                                   Int
  description                            String?
  defaultTotalFeeAmount                  Decimal?                                @db.Decimal(10, 2)
  defaultAdmissionFeeAmount              Decimal?                                @db.Decimal(10, 2)
  createdAt                              DateTime                                @default(now())
  updatedAt                              DateTime                                @updatedAt
  tenant                                 Tenant                                  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  students                               Student[]
  worksheets                             Worksheet[]
  materials                              Material[]
  competitions                           Competition[]
  levelRules                             LevelRule[]
  studentLevelCompletions                StudentLevelCompletion[]
  progressionFromEntries                 StudentLevelProgressionHistory[]        @relation("ProgressionFromLevel")
  progressionToEntries                   StudentLevelProgressionHistory[]        @relation("ProgressionToLevel")
  worksheetTemplates                     WorksheetTemplate[]
  questionBankEntries                    QuestionBank[]
  certificates                           Certificate[]
  enrollments                            Enrollment[]
  examEnrollmentEntries                  ExamEnrollmentEntry[]                   @relation("ExamEnrollmentEntryLevel")
  examPracticePlans                      ExamPracticePlan[]
  examTextbookData                       ExamTextbookData[]
  examEnrollmentLevelWorksheetSelections ExamEnrollmentLevelWorksheetSelection[]

